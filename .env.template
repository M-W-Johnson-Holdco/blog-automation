### Active company (peachtree | tc) — or pass --company to pipeline.py / write_tournament.py
COMPANY="peachtree"

### Tavily API (per-company account — use the key for the COMPANY above)
TAVILY_API_KEY=""

### Slack Approval Bot (per-company Slack app/channel — match COMPANY above)
SLACK_APPROVAL_CHANNEL=""
SLACK_APPROVAL_BOT_TOKEN="" # workspace level access 
# Called "Blog Automation" as a Socket Mode Token (local listener only; not needed for cloud webhook)
SLACK_APPROVAL_TOKEN=""

# Slack Events API webhook (cloud deploy only — see docs/cloudflare-workers-setup.md or docs/slack-webhook-setup.md)
SLACK_SIGNING_SECRET=""
GITHUB_TOKEN=""                          # PAT with actions:write (Cloudflare Worker or Render webhook)
GITHUB_REPOSITORY=""                     # owner/repo
GITHUB_REF_NAME="main"

### LLM provider (Claude default; Together for rollback)
LLM_PROVIDER="anthropic"          # anthropic | together

ANTHROPIC_API_KEY=""

# Per-role Claude models (defaults in claude_models.py if unset)
CLAUDE_EVALUATION_MODEL="claude-sonnet-4-6"
CLAUDE_WRITING_MODEL="claude-opus-4-8"
CLAUDE_FACT_AUDIT_MODEL="claude-sonnet-4-6"
CLAUDE_SCORER_MODEL="claude-sonnet-4-6"
CLAUDE_WRITING_MAX_TOKENS="6000"

### Together.ai (rollback — optional when LLM_PROVIDER=anthropic)
